# Copy this to .env for local development (never commit the real .env file)

# Required: used for mock interview scoring only (GPT-5.5 direct)
OPENAI_API_KEY=sk-...

# Required: routes quiz/notes/company-intel generation via OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...

# Required: web search for company intel research
TAVILY_API_KEY=tvly-...

# Required: web search for quiz context
EXA_API_KEY=...

# Optional: port for local dev server (Railway sets this automatically in production)
PORT=8787
